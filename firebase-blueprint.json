{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A website project being monitored",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the project" },
        "domain": { "type": "string", "description": "Domain of the website" },
        "urls": { "type": "array", "items": { "type": "string" }, "description": "List of URLs to monitor" },
        "checkFrequency": { "type": "string", "enum": ["hourly", "daily", "weekly"], "description": "How often to check for changes" },
        "lastChecked": { "type": "string", "format": "date-time", "description": "Last time the project was scanned" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was created" },
        "userId": { "type": "string", "description": "ID of the user who owns the project" }
      },
      "required": ["name", "domain", "urls", "checkFrequency", "createdAt", "userId"]
    },
    "Snapshot": {
      "title": "Snapshot",
      "description": "A point-in-time capture of a page's metadata",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "ID of the parent project" },
        "url": { "type": "string", "description": "URL of the page" },
        "metadata": { "type": "object", "description": "The captured metadata" },
        "isBaseline": { "type": "boolean", "description": "Whether this is the baseline snapshot" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the snapshot was taken" }
      },
      "required": ["projectId", "url", "metadata", "isBaseline", "createdAt"]
    },
    "ChangeEvent": {
      "title": "ChangeEvent",
      "description": "A detected change between snapshots",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "ID of the parent project" },
        "url": { "type": "string", "description": "URL of the page" },
        "type": { "type": "string", "enum": ["SEO", "Content", "Structure", "Links", "Images", "Status"], "description": "Type of change" },
        "field": { "type": "string", "description": "The specific field that changed" },
        "oldValue": { "type": "any", "description": "The value before the change" },
        "newValue": { "type": "any", "description": "The value after the change" },
        "criticality": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"], "description": "How critical the change is" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the change was detected" },
        "isViewed": { "type": "boolean", "description": "Whether the user has seen this change" },
        "userId": { "type": "string", "description": "ID of the user who owns the project" }
      },
      "required": ["projectId", "url", "type", "field", "criticality", "timestamp", "isViewed", "userId"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects"
    },
    "/snapshots/{snapshotId}": {
      "schema": "Snapshot",
      "description": "Collection of page snapshots"
    },
    "/changes/{changeId}": {
      "schema": "ChangeEvent",
      "description": "Collection of detected changes"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
